# Copernicus CDS API (for ERA5 downloads)
CDSAPI_URL=https://cds.climate.copernicus.eu/api/v2
CDSAPI_KEY=your-key-here

# AWS SageMaker
AWS_DEFAULT_REGION=us-east-1
AWS_SAGEMAKER_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT:role/SageMakerRole
S3_BUCKET=your-fedclimate-bucket

# Experiment tracking
WANDB_API_KEY=your-wandb-key
WANDB_PROJECT=fedclimate
